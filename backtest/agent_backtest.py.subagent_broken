def scan_market(phase: str = "train", limit: int = TOP_N) -> dict:
    """扫描市场候选股票"""
    conn = None
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        start, end = PHASES.get(phase, PHASES["train"])
        rows = cursor.execute("""
            SELECT symbol, COUNT(*) as days, SUM(volume) as total_vol,
                   AVG(rsi14) as avg_rsi, MAX(rsi14) as max_rsi, MIN(rsi14) as min_rsi
            FROM kline_daily
            WHERE trade_date BETWEEN ? AND ?
              AND volume > 0 AND rsi14 IS NOT NULL
            GROUP BY symbol
            HAVING days > 100
            ORDER BY total_vol DESC
            LIMIT ?
        """, (start, end, limit)).fetchall()

        stocks = [{
            "symbol": r[0], "days": r[1],
            "total_vol": round(r[2], 2) if r[2] else 0,
            "avg_rsi": round(r[3], 1) if r[3] else 50,
            "max_rsi": round(r[4], 1) if r[4] else 50,
            "min_rsi": round(r[5], 1) if r[5] else 50,
        } for r in rows]
        return {"ok": True, "phase": phase, "count": len(stocks), "candidates": stocks}
    except Exception as e:
        return {"ok": False, "error": str(e)}
    finally:
        if conn:
            conn.close()


def _compute_adx(highs, lows, closes, period: int = 14) -> tuple:
    """计算 ADX/+DI/-DI，返回 (adx, plus_di, minus_di) 列表，与输入等长（前 period 个为 None）"""
    n = len(highs)
    if n < period + 1:
        return [None] * n, [None] * n, [None] * n

    tr_list = [None] * period
    plus_dm = [None] * period
    minus_dm = [None] * period

    for i in range(1, period + 1):
        hl = highs[i] - lows[i]
        hc = abs(highs[i] - closes[i - 1])
        lc = abs(lows[i] - closes[i - 1])
        tr_list[i - 1] = max(hl, hc, lc)
        high_diff = highs[i] - highs[i - 1]
        low_diff = lows[i - 1] - lows[i]
        plus_dm[i - 1] = high_diff if high_diff > low_diff and high_diff > 0 else 0
        minus_dm[i - 1] = low_diff if low_diff > high_diff and low_diff > 0 else 0

    # 初始 ATR/DI
    atr = sum(tr_list) / period
    plus_di_sum = sum(plus_dm)
    minus_di_sum = sum(minus_dm)

    adx_list = [None] * (period * 2)
    plus_di_list = [None] * (period * 2)
    minus_di_list = [None] * (period * 2)

    for i in range(period, n):
        idx = i - period
        hl = highs[i] - lows[i]
        hc = abs(highs[i] - closes[i - 1])
        lc = abs(lows[i] - closes[i - 1])
        tr = max(hl, hc, lc)
        pdm = max(highs[i] - highs[i - 1], 0) if (highs[i] - highs[i - 1]) > (lows[i - 1] - lows[i]) else 0
        mdm = max(lows[i - 1] - lows[i], 0) if (lows[i - 1] - lows[i]) > (highs[i] - highs[i - 1]) else 0

        atr = (atr * (period - 1) + tr) / period
        plus_di_sum = (plus_di_sum * (period - 1) + pdm) / period
        minus_di_sum = (minus_di_sum * (period - 1) + mdm) / period

        plus_di = (plus_di_sum / atr * 100) if atr != 0 else 0
        minus_di = (minus_di_sum / atr * 100) if atr != 0 else 0
        dx = abs(plus_di - minus_di) / (plus_di + minus_di) * 100 if (plus_di + minus_di) != 0 else 0

        # 平滑 ADX
        if i == period * 2 - 1:
            adx_val = sum(adx_list[i - period + 1:i]) / period if i > period else dx
            adx_list[i] = adx_val
        elif i > period * 2 - 1:
            adx_val = (adx_list[i - 1] * (period - 1) + dx) / period
            adx_list[i] = adx_val
        else:
            adx_list[i] = None

        plus_di_list[i] = plus_di
        minus_di_list[i] = minus_di

    return adx_list, plus_di_list, minus_di_list


def backtest_signal(symbol: str, signal_type: str, params: dict,
                    phase: str = "train") -> dict:
    """对单只股票回测"""
    conn = None
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        start, end = PHASES.get(phase, PHASES["train"])
        rows = cursor.execute(f"""
            SELECT trade_date, open, high, low, close, volume,
                   rsi14, ma5, ma10, ma20,
                   macd_dif, macd_dea, macd_hist,
                   boll_lower, boll_upper, boll_mid,
                   kdj_k, kdj_d, kdj_j,
                   cci_14, wr_14,
                   bias_6, bias_12, bias_26,
                   psy_12, psy_24,
                   vr, ar, brar,
                   dma_dif, dma_ma10,
                   expma1, expma2,
                   tema_12, tema_26,
                   turnover_rate
            FROM kline_daily
            WHERE symbol = ? AND trade_date BETWEEN ? AND ?
            ORDER BY trade_date ASC
        """, (symbol, start, end)).fetchall()

        if len(rows) < 30:
            return {"ok": False, "error": f"数据不足: {len(rows)}条"}

        # 字段索引映射
        # 0:trade_date 1:open 2:high 3:low 4:close 5:volume
        # 6:rsi14 7:ma5 8:ma10 9:ma20
        # 10:macd_dif 11:macd_dea 12:macd_hist
        # 13:boll_lower 14:boll_upper 15:boll_mid
        # 16:kdj_k 17:kdj_d 18:kdj_j
        # 19:cci_14 20:wr_14
        # 21:bias_6 22:bias_12 23:bias_26
        # 24:psy_12 25:psy_24
        # 26:vr 27:ar 28:brar
        # 29:dma_dif 30:dma_ma10
        # 31:expma1 32:expma2
        # 33:tema_12 34:tema_26
        # 35:turnover_rate

        dates    = [r[0]  for r in rows]
        opens    = [r[1]  for r in rows]
        highs    = [r[2]  for r in rows]
        lows     = [r[3]  for r in rows]
        closes   = [r[4]  for r in rows]
        volumes  = [r[5]  for r in rows]
        rsi14_l  = [r[6]  for r in rows]
        ma5_l    = [r[7]  for r in rows]
        ma10_l   = [r[8]  for r in rows]
        ma20_l   = [r[9]  for r in rows]
        macd_dif = [r[10] for r in rows]
        macd_dea = [r[11] for r in rows]
        macd_hst = [r[12] for r in rows]
        boll_low = [r[13] for r in rows]
        boll_up  = [r[14] for r in rows]
        boll_mid = [r[15] for r in rows]
        kdj_k    = [r[16] for r in rows]
        kdj_d    = [r[17] for r in rows]
        kdj_j    = [r[18] for r in rows]
        cci_14   = [r[19] for r in rows]
        wr_14    = [r[20] for r in rows]
        bias_6   = [r[21] for r in rows]
        bias_12  = [r[22] for r in rows]
        bias_26  = [r[23] for r in rows]
        psy_12   = [r[24] for r in rows]
        psy_24   = [r[25] for r in rows]
        vr       = [r[26] for r in rows]
        ar       = [r[27] for r in rows]
        brar     = [r[28] for r in rows]
        dma_dif  = [r[29] for r in rows]
        dma_ma10 = [r[30] for r in rows]
        expma1   = [r[31] for r in rows]
        expma2   = [r[32] for r in rows]
        tema_12  = [r[33] for r in rows]
        tema_26  = [r[34] for r in rows]
        turnover = [r[35] for r in rows]

        # 预计算 ADX（用于 adx_plusDI）
        adx_list, plus_di_list, minus_di_list = _compute_adx(highs, lows, closes)

        hold_days = params.get("hold_days", 7)
        signal_count = win_count = 0
        total_return = 0.0
        trades = []

        i = 0
        while i < len(rows) - hold_days:
            trigger = False

            # ==================== 已有信号 ====================
            if signal_type == "rsi":
                thresh = params.get("rsi_thresh", 20)
                if rsi14_l[i] is not None and rsi14_l[i] <= thresh:
                    trigger = True

            elif signal_type == "bb_break":
                thresh = params.get("bb_thresh", 1.0)
                if boll_low[i] is not None and closes[i] <= boll_low[i] * thresh:
                    trigger = True

            elif signal_type == "macd_goldCross":
                if macd_dif[i] is not None and macd_dea[i] is not None:
                    if i > 0 and macd_dif[i] > macd_dea[i] and macd_dif[i-1] <= macd_dea[i-1]:
                        trigger = True

            elif signal_type == "ma_cross":
                ma_short_key = params.get("ma_short", "ma5")
                ma_long_key = params.get("ma_long", "ma10")
                ma_short = {"ma5": ma5_l, "ma10": ma10_l, "ma20": ma20_l}.get(ma_short_key)
                ma_long = {"ma5": ma5_l, "ma10": ma10_l, "ma20": ma20_l}.get(ma_long_key)
                if ma_short and ma_long:
                    if ma_short[i] is not None and ma_long[i] is not None:
                        if i > 0 and ma_short[i] > ma_long[i] and ma_short[i-1] <= ma_long[i-1]:
                            trigger = True

            elif signal_type == "bollinger_bounce":
                if boll_low[i] is not None and closes[i] <= boll_low[i]:
                    trigger = True

            elif signal_type == "volume_breakout":
                vol_thresh = params.get("vol_mult", 1.5)
                avg_v = sum(volumes[max(0, i-20):i]) / min(20, i+1) if i > 0 else volumes[0]
                if volumes[i] > avg_v * vol_thresh:
                    trigger = True

            # ==================== KDJ 系列 ====================
            elif signal_type == "kdj_goldCross":
                if kdj_k[i] is not None and kdj_d[i] is not None:
                    if i > 0 and kdj_k[i] > kdj_d[i] and kdj_k[i-1] <= kdj_d[i-1]:
                        trigger = True

            elif signal_type == "kdj_oversold":
                thresh = params.get("kdj_thresh", 20)
                if kdj_j[i] is not None and kdj_j[i] < thresh:
                    trigger = True

            # ==================== CCI ====================
            elif signal_type == "cci_oversold":
                thresh = params.get("cci_thresh", -100)
                if cci_14[i] is not None and cci_14[i] < thresh:
                    trigger = True

            # ==================== WR 威廉指标 ====================
            elif signal_type == "wr_oversold":
                thresh = params.get("wr_thresh", 80)
                if wr_14[i] is not None and wr_14[i] > thresh:
                    trigger = True

            # ==================== BIAS 乖离率 ====================
            elif signal_type == "bias_oversold":
                period = params.get("bias_period", 12)
                thresh = params.get("bias_thresh", -5)
                bias = {"6": bias_6, "12": bias_12, "26": bias_26}.get(str(period))
                if bias and bias[i] is not None and bias[i] < thresh:
                    trigger = True

            elif signal_type == "bias_rebound":
                period = params.get("bias_period", 12)
                thresh = params.get("bias_thresh", -8)
                bias = {"6": bias_6, "12": bias_12, "26": bias_26}.get(str(period))
                if bias and bias[i] is not None and bias[i] < thresh:
                    # 今日BIAS在阈值以下，且昨日BIAS更低（反弹迹象）
                    if i > 0 and bias[i-1] is not None and bias[i-1] < bias[i]:
                        trigger = True

            # ==================== PSY 心理线 ====================
            elif signal_type == "psy_oversold":
                period = params.get("psy_period", 12)
                thresh = params.get("psy_thresh", 25)
                psy = {"12": psy_12, "24": psy_24}.get(str(period))
                if psy and psy[i] is not None and psy[i] < thresh:
                    trigger = True

            # ==================== VR 容量比率 ====================
            elif signal_type == "vr_oversold":
                thresh = params.get("vr_thresh", 70)
                if vr[i] is not None and vr[i] < thresh:
                    trigger = True

            # ==================== DMA 差分移动平均 ====================
            elif signal_type == "dma_goldCross":
                if dma_dif[i] is not None and dma_ma10[i] is not None:
                    if i > 0 and dma_dif[i] > dma_ma10[i] and dma_dif[i-1] <= dma_ma10[i-1]:
                        trigger = True

            # ==================== EXPMA 指数平滑 ====================
            elif signal_type == "expma_goldCross":
                if expma1[i] is not None and expma2[i] is not None:
                    if i > 0 and expma1[i] > expma2[i] and expma1[i-1] <= expma2[i-1]:
                        trigger = True

            # ==================== TEMA 三重指数平滑 ====================
            elif signal_type == "tema_goldCross":
                if tema_12[i] is not None and tema_26[i] is not None:
                    if i > 0 and tema_12[i] > tema_26[i] and tema_12[i-1] <= tema_26[i-1]:
                        trigger = True

            # ==================== MACD 信号增强 ====================
            elif signal_type == "macd_hist_turn":
                # MACD柱状图由负转正
                if macd_hst[i] is not None and macd_hst[i] > 0:
                    if i > 0 and macd_hst[i-1] is not None and macd_hst[i-1] <= 0:
                        trigger = True

            elif signal_type == "macd_divergence":
                # 底背离：价格新低但DIF未新低
                if i >= 20:
                    price_low_window = min(closes[max(0, i-20):i+1])
                    dif_low_window = min(macd_dif[max(0, i-20):i+1])
                    if closes[i] == price_low_window and macd_dif[i] > dif_low_window:
                        trigger = True

            # ==================== 换手率 ====================
            elif signal_type == "turnover_spike":
                mult = params.get("turnover_mult", 2.0)
                avg_to = sum(turnover[max(0, i-20):i]) / min(20, i+1) if i > 0 else (turnover[0] or 0)
                if turnover[i] is not None and avg_to > 0 and turnover[i] > avg_to * mult:
                    trigger = True

            # ==================== 成交量综合 ====================
            elif signal_type == "volume_shrink":
                shrink_ratio = params.get("shrink_ratio", 0.3)
                avg_v = sum(volumes[max(0, i-20):i]) / min(20, i+1) if i > 0 else volumes[0]
                if volumes[i] < avg_v * shrink_ratio and volumes[i] < volumes[max(0, i-1)]:
                    trigger = True

            elif signal_type == "volume_mean_reversion":
                vol_period = params.get("vol_period", 5)
                if i >= vol_period:
                    recent_avg = sum(volumes[i-vol_period+1:i+1]) / vol_period
                    past_avg = sum(volumes[max(0, i-vol_period*2):i-vol_period+1]) / min(vol_period, i-vol_period+1)
                    # 前期缩量（低于过去均量），今日放量（高于近期均量）
                    if past_avg > 0 and volumes[i] > recent_avg and past_avg < recent_avg * 0.8:
                        trigger = True

            # ==================== 多周期共振 ====================
            elif signal_type == "rsi_ma_combo":
                rsi_thresh = params.get("rsi_thresh", 30)
                # RSI超卖 + MA多头排列（ma5>ma10>ma20）
                rsi_ok = rsi14_l[i] is not None and rsi14_l[i] <= rsi_thresh
                ma_ok = (ma5_l[i] is not None and ma10_l[i] is not None and ma20_l[i] is not None and
                         ma5_l[i] > ma10_l[i] > ma20_l[i])
                if rsi_ok and ma_ok:
                    trigger = True

            elif signal_type == "kdj_macd_combo":
                # KDJ金叉 + MACD金叉共振
                kdj_cross = (i > 0 and kdj_k[i] is not None and kdj_d[i] is not None and
                             kdj_k[i] > kdj_d[i] and kdj_k[i-1] <= kdj_d[i-1])
                macd_cross = (i > 0 and macd_dif[i] is not None and macd_dea[i] is not None and
                               macd_dif[i] > macd_dea[i] and macd_dif[i-1] <= macd_dea[i-1])
                if kdj_cross and macd_cross:
                    trigger = True

            # ==================== 趋势确认 ====================
            elif signal_type == "adx_plusDI":
                thresh = params.get("adx_thresh", 20)
                adx_val = adx_list[i]
                pd_val = plus_di_list[i]
                md_val = minus_di_list[i]
                if adx_val is not None and pd_val is not None and md_val is not None:
                    if adx_val > thresh and pd_val > md_val:
                        trigger = True

            # ==================== 支撑压力 ====================
            elif signal_type == "price_support":
                n_days = params.get("n_days", 20)
                if i >= n_days:
                    window_low = min(lows[i-n_days:i])
                    if closes[i] <= window_low * 1.01:  # 触及N日最低价附近
                        trigger = True

            elif signal_type == "price_resistance":
                n_days = params.get("n_days", 20)
                if i >= n_days:
                    window_high = max(highs[i-n_days:i])
                    if closes[i] >= window_high * 0.99:  # 触及N日最高价附近
                        trigger = True

            if trigger:
                signal_count += 1
                ep = rows[i + 1][1] if i + 1 < len(rows) else rows[i][1]
                ed = dates[i + 1]    if i + 1 < len(rows) else dates[i]
                xi = min(i + hold_days, len(rows) - 1)
                xp = rows[xi][4]
                ret = (xp - ep) / ep * 100
                total_return += ret
                if ret > 0:
                    win_count += 1
                trades.append({
                    "symbol": symbol, "entry_date": ed, "entry_price": round(ep, 2),
                    "exit_date": dates[xi], "exit_price": round(xp, 2),
                    "return_pct": round(ret, 2), "signal": signal_type,
                })
                i += hold_days
            else:
                i += 1

        if signal_count == 0:
            return {"ok": False, "error": "无信号"}

        return {
            "ok": True, "symbol": symbol, "signal_type": signal_type,
            "params": params, "phase": phase,
            "signal_count": signal_count, "win_count": win_count,
            "win_rate": round(win_count / signal_count * 100, 1),
            "avg_return": round(total_return / signal_count, 2),
            "total_return": round(total_return, 2),
            "trades": trades[:5],
        }
    except Exception as e:
        return {"ok": False, "error": str(e)}
    finally:
        if conn:
            conn.close()


def evaluate_result(result: dict) -> dict:
    """评估是否达标"""
    if not result.get("ok"):
        return {"ok": False, "qualified": False, "reason": result.get("error", "回测失败")}
    wr = result.get("win_rate", 0)
    ar = result.get("avg_return", 0)
    sc = result.get("signal_count", 0)
    if sc < 5:
        return {"ok": True, "qualified": False, "reason": f"信号太少({sc}笔)", "win_rate": wr, "avg_return": ar}
    if wr < TARGET_WIN_RATE:
        return {"ok": True, "qualified": False, "reason": f"胜率{wr}%<{TARGET_WIN_RATE}%", "win_rate": wr, "avg_return": ar}
    if ar < 0:
        return {"ok": True, "qualified": False, "reason": f"均益{ar}%<0", "win_rate": wr, "avg_return": ar}
    return {"ok": True, "qualified": True, "win_rate": wr, "avg_return": ar, "signal_count": sc,
            "reason": f"✅ 达标: 胜率{wr}%, 均益{ar}%, {sc}笔"}


def push_candidate(candidate: dict) -> dict:
    """推送达标策略"""
    f = Path(__file__).parent.parent / "data" / "results" / "agent_candidates.jsonl"
    f.parent.mkdir(parents=True, exist_ok=True)
    with open(f, "a") as fp:
        fp.write(json.dumps({**candidate, "found_at": datetime.now().isoformat()}, ensure_ascii=False) + "\n")
    return {"ok": True, "count": sum(1 for _ in open(f))}


# ===================== 工具调度表 =====================

TOOL_HANDLERS = {
    "scan_market":     lambda **kw: scan_market(**kw),
    "backtest_signal": lambda **kw: backtest_signal(**kw),
    "evaluate_result":   lambda **kw: evaluate_result(**kw),
    "push_candidate":   lambda **kw: push_candidate(**kw),
}


def run_tool(name: str, arguments: dict) -> str:
    handler = TOOL_HANDLERS.get(name)
    if not handler:
        return json.dumps({"ok": False, "error": f"Unknown tool: {name}"}, ensure_ascii=False)
    try:
        result = handler(**arguments)
        return json.dumps(result, ensure_ascii=False)
    except Exception as e:
        return json.dumps({"ok": False, "error": str(e)}, ensure_ascii=False)


# ===================== TodoWrite 管理器（Layer 3）=====================

class TodoManager:
    def __init__(self):
        self.items = []
        self.rounds_since_update = 0

    def update(self, items: list):
        if sum(1 for it in items if it.get("status") == "in_progress") > 1:
            raise ValueError("Only one task can be in_progress at a time")
        self.items = items
        self.rounds_since_update = 0

    def tick(self):
        self.rounds_since_update += 1

    def should_nag(self) -> bool:
        return self.rounds_since_update >= 3

    def get_display(self) -> str:
        if not self.items:
            return "(no tasks)"
        return "\n".join(
            f"{ {'pending':'🔲','in_progress':'🔵','completed':'✅'}.get(it.get('status'),'⬜')} "
            f"[{it.get('status')}] {it.get('content','')}"
            for it in self.items
        )


# ===================== LLM 调用 =====================

def call_llm(messages: list, model: str = MODEL) -> dict:
    import urllib.request, urllib.error

    payload = {
        "model": model,
        "messages": messages,
        "max_tokens": MAX_TOKENS,
    }

    req = urllib.request.Request(
        f"{MINIMAX_BASE_URL}/messages",
        data=json.dumps(payload).encode(),
        headers={
            "Authorization": f"Bearer {MINIMAX_API_KEY}",
            "Content-Type": "application/json",
            "User-Agent": "curl/7.81.0",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        return {"error": f"HTTP {e.code}: {e.read().decode()}"}
    except Exception as e:
        return {"error": str(e)}


