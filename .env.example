# Stock Monitor App Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
DEBUG=false

# Database
DB_PATH=stock_data.db

# Stock
STOCK_SYMBOL=sz002149

# Security
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
API_KEY=your_api_key_here
# Set AUTH_ENABLED=false to skip authentication (development only)
AUTH_ENABLED=true

# CORS - comma-separated allowed origins (no spaces after commas)
CORS_ORIGINS=http://localhost:3000

# Feishu (Lark) Configuration
# Get these from https://open.feishu.cn/app
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_DEFAULT_RECEIVER=

# Logging
LOG_LEVEL=INFO
